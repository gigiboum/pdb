<section class="py-20 bg-gray-100">
  <div class="container mx-auto px-4">
    <h2 class="text-4xl font-serif font-bold text-center mb-16">Services</h2>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      {steps.map((step, index) => (
        <div class="bg-gray-50 p-8 rounded-lg text-center" id={`step-${index.toString()}`}>
          <svg class="w-16 h-16 mx-auto mb-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-inejoin="round" stroke-width={1} d={step.icon} />
          </svg>
          <p class="text-gray-700">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
