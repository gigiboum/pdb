---
const testimonials = [
  {
    quote: "Pascale is very professional and friendly, 10/10.",
    author: "Susan",
    service: "Mobile notary services for house sale signing"
  },
  {
    quote: "Without Pascale I would have never been able to sell my house.",
    author: "Jill Feldman",
    service: "Chief Operating Officer"
  },
  {
    quote: "After starting our members on this platform, we've seen significant decreases in utilization and improved outcomes. The program more than paid for itself.",
    author: "Ian Straayer",
    service: "Manager of Quality Improvement"
  },
  {
    quote: "Seeing more than 90% of our members engage with this platform daily is a testament to the program's effectiveness. We've seen significant improvements in our members' health outcomes and quality of life.",
    author: "Renee Kieffer",
    service: "Nurse Practitioner"
  },
];
---

<section class="bg-gray-100 py-20">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl font-serif font-bold text-center mb-12">Testimonials</h2>
    <div class="flex overflow-x-auto snap-x snap-mandatory">
      {testimonials.map((testimonial) => (
        <div class="flex-shrink-0 w-full sm:w-1/2 md:w-1/3 snap-start">
          <div class="bg-white rounded-lg shadow-lg p-8 mx-4">
            <p class="text-gray-600 italic mb-4">{testimonial.quote}</p>
            <div class="flex items-center">
              <div>
                <p class="font-semibold">{testimonial.author}</p>
                <p class="text-sm text-gray-500">{testimonial.service}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
