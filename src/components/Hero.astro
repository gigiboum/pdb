---
import { Image } from 'astro:assets';
import heroImg from '../assets/placeholder-image.jpg';
---

<section class="bg-white py-20">
  <div class="container mx-auto px-4">
    <div class="flex flex-col lg:flex-row items-center">
      <div class="lg:w-1/2 lg:pr-12">
        <h1 class="text-5xl lg:text-6xl font-serif font-bold text-gray-900 mb-6">
          DMV Area Notary Services
        </h1>
        <p class="text-xl text-gray-700 mb-8">
          Lorem ipsum. Photo by <a href="https://unsplash.com/@slrncl?utm_source=unsplash&utm_medium=referral&utm_content=creditCopyText">Nicolas Solerieu</a> on <a href="https://unsplash.com/photos/a-stack-of-rocks-sitting-on-top-of-each-other-7AM9xVtFlZ0?utm_source=unsplash&utm_medium=referral&utm_content=creditCopyText">Unsplash</a>
      
        </p>
      </div>
      <div class="lg:w-1/2 mt-10 lg:mt-0 relative">
        <Image 
          src={heroImg} 
          alt="Happy family" 
          class="rounded-lg shadow-xl"
          width={600}
          height={400}
        />
      </div>
    </div>
  </div>
</section>
